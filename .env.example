# StreamWeaver environment template
# Only includes keys actually referenced in app source (src/** and server.ts).

# --- Core URLs ---
NEXTAUTH_URL=http://localhost:3100
NEXT_PUBLIC_BASE_URL=http://localhost:3100
NEXT_PUBLIC_STREAMWEAVE_URL=http://localhost:3100

# --- WebSocket (optional; defaults used if omitted) ---
WS_PORT=8090
NEXT_PUBLIC_STREAMWEAVE_WS_HOST=127.0.0.1
NEXT_PUBLIC_STREAMWEAVE_WS_PORT=8090
NEXT_PUBLIC_STREAMWEAVE_WS_URL=

# --- Twitch ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
NEXT_PUBLIC_TWITCH_CLIENT_ID=
NEXT_PUBLIC_TWITCH_CLIENT_SECRET=
NEXT_PUBLIC_HARDCODED_ADMIN_TWITCH_ID=
TWITCH_BROADCASTER_ID=
TWITCH_BROADCASTER_USERNAME=
NEXT_PUBLIC_TWITCH_BROADCASTER_USERNAME=
NEXT_PUBLIC_TWITCH_BOT_USERNAME=

# Optional (used by certain Twitch helpers)
TWITCH_USER_OAUTH_TOKEN=

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_INVITE_LINK=
DISCORD_TAG_WEBHOOK_URL=

# Optional (future): route privileged Discord bot actions through a hosted broker
# instead of requiring DISCORD_BOT_TOKEN on the local machine.
# When DISCORD_BROKER_URL is set, src/services/discord.ts will POST to these endpoints:
#   /discord/send-message
#   /discord/upload-file
#   /discord/get-channel-messages
#   /discord/delete-message
#   /discord/get-user
DISCORD_BROKER_URL=
# Optional shared secret for broker requests (placeholder for now).
DISCORD_BROKER_API_KEY=

NEXT_PUBLIC_DISCORD_LOG_CHANNEL_ID=
NEXT_PUBLIC_DISCORD_AI_CHAT_CHANNEL_ID=
NEXT_PUBLIC_DISCORD_SHOUTOUT_CHANNEL_ID=
NEXT_PUBLIC_DISCORD_SHARE_CHANNEL_ID=
NEXT_PUBLIC_DISCORD_METRICS_CHANNEL_ID=
DISCORD_RAID_TRAIN_CHANNEL_ID=

# Used to authenticate internal bot/server requests (e.g. /api/chat/log)
BOT_SECRET_KEY=

# --- AI / TTS ---
GEMINI_API_KEY=
GOOGLE_GENAI_API_KEY=
GEMINI_MODEL=
GOOGLE_GENAI_MODEL=
NEXT_PUBLIC_GEMINI_API_KEY=
NEXT_DEFAULT_TTS_VOICE=
ELEVENLABS_API_KEY=
INWORLD_API_KEY=
OPENAI_API_KEY=

# --- Hosted Broker (optional) ---
# Single-switch mode: when BROKER_BASE_URL is set, these API routes will forward
# to the broker instead of using local machine secrets:
#   - /api/ai/generate
#   - /api/google-tts
#   - /api/tts
#   - Speech-to-Text server action (src/services/speech.ts)
#     forwards to: POST {BROKER_BASE_URL}/v1/speech-to-text
#
# You can also put BROKER_BASE_URL in tokens/user-config.json; the app loads that
# file and applies values into process.env at startup.
BROKER_BASE_URL=

# --- Google Cloud credentials (Speech-to-Text + Text-to-Speech) ---
# Option A (recommended): point to a local service account key file.
# Windows example: GOOGLE_APPLICATION_CREDENTIALS=C:\\streamweaver-secrets\\gcp-service-account.json
# Project-relative example: GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# Option B: provide the full service account JSON inline (must be valid JSON).
# Tip: private_key newlines should be escaped as \n in .env.
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Raid Train ---
EMERGENCY_SLOTS_LOOKAHEAD_HOURS=
RAID_TRAIN_SLOT_COST=
EMERGENCY_SLOT_COST=

# --- OBS (optional) ---
OBS_WS_URL=
OBS_WS_PASSWORD=
NEXT_PUBLIC_OBS_IP=127.0.0.1
NEXT_PUBLIC_OBS_PORT=4455

# --- BRB Clip Player ---
BRB_SCENE=BRB
BRB_BROWSER_SOURCE=ClipPlayer
BRB_PLAYER_URL=http://localhost:3100/brb-player

# --- Space Mountain Gamble ---
GAMBLE_OVERLAY_SCENE=VRFlad Fast Track Alerts
GAMBLE_OVERLAY_SOURCE=spmt-overlay
GAMBLE_DISCORD_WEBHOOK=

# --- Firebase Admin (optional; enables Firestore-backed NextAuth adapter) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- YouTube (optional) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3100/auth/youtube/callback

# --- Advanced / optional features ---
ALLOW_DATA_FILE_IO=false
APOLLO_STATION_WS_URL=
DASHBOARD_MODE=false
